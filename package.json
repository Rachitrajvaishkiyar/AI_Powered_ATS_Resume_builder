{
  "name": "resumeai-pro",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*"
  ],
  "overrides": {
    "postcss": "^8.5.15"
  },
  "scripts": {
    "dev:web": "cd apps/web && next dev",
    "dev:api": "cd apps/api && npm run dev",
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:api\"",
    "build:web": "cd apps/web && next build",
    "build:api": "cd apps/api && npm run build",
    "build": "npm run build:web && npm run build:api",
    "lint:web": "cd apps/web && next lint",
    "start:api": "cd apps/api && node dist/server.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "prisma": "^7.8.0"
  }
}
